---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import SiteFooter from "../components/SiteFooter.astro";
import Section from "../components/Section.astro";
import NavLink from "../components/NavLink.astro";

const instagramUrl = "https://www.instagram.com/ira.mako/";

const details = [
  {
    label: "Sklep firmowy",
    lines: ["pl. Uniwersytecki 7", "50–137 Wrocław"],
  },
  {
    label: "Dane firmy",
    lines: ["iramako Irena Makowska", "NIP 9121835398", "REGON 541674780"],
  },
];
---

<BaseLayout title="Kontakt | iramako" description="Skontaktuj się z iramako — sklep firmowy we Wrocławiu, e-mail i Instagram.">
  <main class="min-h-screen w-full">
    <Navbar instagramUrl={instagramUrl} />

    <Section containerClass="py-14 sm:py-[clamp(56px,8vw,110px)]">
      <h1
        class="m-0 text-[clamp(3rem,9vw,6rem)] font-bold leading-[0.98] tracking-[-0.04em] text-ink"
      >
        Napisz do nas
      </h1>
      <div class="mt-10 flex flex-col gap-4 text-[clamp(1.2rem,1.8vw,1.7rem)] font-medium text-ink">
        <NavLink href="mailto:centrala@iramako.pl" splash="szary"
          >centrala@iramako.pl</NavLink
        >
        <NavLink
          href={instagramUrl}
          target="_blank"
          rel="noreferrer"
          splash="kolko13">@ira.mako</NavLink
        >
      </div>
    </Section>

    <Section
      border="none"
      containerClass="grid grid-cols-1 gap-x-[clamp(32px,6vw,120px)] gap-y-12 py-16 sm:py-[clamp(56px,7vw,110px)] sm:grid-cols-2"
    >
      {
        details.map((block) => (
          <div>
            <h2 class="m-0 mb-4 text-sm font-bold uppercase tracking-[0.12em] text-muted">
              {block.label}
            </h2>
            <p class="m-0 text-[clamp(1.1rem,1.4vw,1.4rem)] leading-relaxed text-ink">
              {block.lines.map((line) => (
                <span class="block">{line}</span>
              ))}
            </p>
          </div>
        ))
      }
    </Section>

    <SiteFooter instagramUrl={instagramUrl} />
  </main>
</BaseLayout>
