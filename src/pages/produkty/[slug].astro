---
import { Image } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navbar from "../../components/Navbar.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import Section from "../../components/Section.astro";
import Button from "../../components/Button.astro";
import ContactIcon from "../../components/icons/Contact.astro";
import { products, categoryLabels } from "../../data/products";

export function getStaticPaths() {
  return products.map((product) => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

const { product } = Astro.props;
const instagramUrl = "https://www.instagram.com/ira.mako/";

const schema = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: `${product.name} — ${product.fullName}`,
  description: product.intro,
  image: new URL(product.image.src, Astro.site).toString(),
  brand: { "@type": "Brand", name: "iramako" },
  category: categoryLabels[product.category],
  offers: product.variants.map((variant) => ({
    "@type": "Offer",
    priceCurrency: "PLN",
    price: variant.price.match(/\d+/)?.[0],
    availability: "https://schema.org/InStock",
  })),
};
---

<BaseLayout
  title={`${product.name} | iramako`}
  description={product.intro}
  image={product.image.src}
  imageAlt={product.alt}
>
  <script
    type="application/ld+json"
    set:html={JSON.stringify(schema)}
    slot="head"
  />
  <main class="min-h-screen w-full">
    <Navbar instagramUrl={instagramUrl} />

    {/* hero */}
    <Section
      containerClass="grid grid-cols-1 items-center gap-11 py-14 sm:py-[clamp(56px,8vw,104px)] lg:grid-cols-[minmax(0,1fr)_minmax(0,1fr)] lg:gap-[clamp(42px,7vw,104px)]"
    >
      <figure
        class="m-0 flex items-center justify-center"
        style={`--accent: ${product.accent}`}
      >
        <Image
          class="max-h-[460px] w-auto object-contain"
          src={product.image}
          alt={product.alt}
          loading="eager"
          fetchpriority="high"
          quality={95}
        />
      </figure>

      <div class="max-w-[560px]">
        <a
          href={`/#${product.category}`}
          class="text-sm uppercase tracking-[0.12em] text-muted hover:text-ink"
          >← {categoryLabels[product.category]}</a
        >
        <h1
          class="m-0 mt-6 text-[clamp(2.4rem,5vw,4rem)] font-bold leading-[1] tracking-[-0.04em] text-ink"
        >
          {product.name}
        </h1>
        <p class="mt-3 text-[clamp(1.1rem,1.6vw,1.45rem)] text-muted">
          {product.fullName}
        </p>
        <div class="mt-8 flex flex-wrap items-baseline gap-x-8 gap-y-2 text-ink">
          {
            product.variants.map((variant) => (
              <span class="text-[clamp(1.2rem,1.7vw,1.6rem)]">
                <span class="font-bold">{variant.price}</span>
                <span class="text-muted"> · {variant.size}</span>
              </span>
            ))
          }
        </div>
        <div class="mt-9">
          <Button href="mailto:centrala@iramako.pl" variant="primary">
            <ContactIcon slot="icon" />
            zamów / zapytaj
          </Button>
        </div>
      </div>
    </Section>

    {/* details-based tabs: exclusive accordion without JS, enhanced into a
        keyboard-navigable tab bar with JS. content stays in the DOM so
        find-in-page still locates (and auto-expands) collapsed panels. */}
    <Section
      border="none"
      containerClass="py-12 sm:py-[clamp(48px,7vw,96px)]"
    >
      <div class="product-tabs" data-product-tabs>
        <details class="tab" name="product-tabs" open>
          <summary class="tab__summary">Opis</summary>
          <div
            class="tab__panel max-w-[760px] text-[clamp(1.05rem,1.2vw,1.22rem)] leading-relaxed text-muted"
          >
            <p class="m-0">{product.intro}</p>
            <p class="mt-6 m-0">
              <span class="font-bold text-ink">Dla kogo? </span>{product.forWhom}
            </p>
            {
              product.scent && (
                <p class="mt-6 m-0">
                  <span class="font-bold text-ink">Zapach. </span>
                  {product.scent}
                </p>
              )
            }
            <h3 class="mt-10 mb-4 text-lg font-bold text-ink">Sposób użycia</h3>
            <ol class="m-0 flex list-decimal flex-col gap-2 pl-5">
              {product.usage.map((step) => <li>{step}</li>)}
            </ol>
          </div>
        </details>

        <details class="tab" name="product-tabs">
          <summary class="tab__summary">Składniki</summary>
          <div class="tab__panel max-w-[760px]">
            <dl class="m-0 border-t border-rule">
              {
                product.ingredients.map((ingredient) => (
                  <div class="border-b border-rule py-5">
                    <dt class="font-medium text-ink">{ingredient.name}</dt>
                    <dd class="m-0 mt-1 text-[clamp(1rem,1.1vw,1.15rem)] leading-relaxed text-muted">
                      {ingredient.description}
                    </dd>
                  </div>
                ))
              }
            </dl>
            <p class="mt-8 text-sm leading-relaxed text-muted">
              <span class="font-bold text-ink">Składniki / Ingredients: </span>
              {product.inci}
            </p>
          </div>
        </details>

        <details class="tab" name="product-tabs">
          <summary class="tab__summary">O produkcie</summary>
          <div
            class="tab__panel max-w-[760px] text-[clamp(1.05rem,1.2vw,1.22rem)] leading-relaxed text-muted"
          >
            {
              product.research.length > 0 && (
                <p class="m-0">
                  <span class="font-bold text-ink">Badania. </span>
                  {product.research.join(" ")}
                </p>
              )
            }
            <p class="mt-6 m-0">
              <span class="font-bold text-ink">Opakowanie. </span>
              {product.packaging}
            </p>
            <p class="mt-6 m-0">
              <span class="font-bold text-ink">Ostrzeżenia. </span>
              {product.warnings}
            </p>
            <p class="mt-6 m-0">
              <span class="font-bold text-ink">Cena. </span>
              {product.variants.map((v) => `${v.size} — ${v.price}`).join(" · ")}
            </p>
          </div>
        </details>
      </div>
    </Section>

    <style>
      /* no-JS / print / find-in-page: plain exclusive accordion */
      .product-tabs {
        border-top: 1px solid var(--color-rule);
      }
      .tab__summary {
        list-style: none;
        cursor: pointer;
        padding: 1rem 0;
        font-weight: 700;
        font-size: clamp(1.3rem, 2.4vw, 2rem);
        letter-spacing: -0.03em;
        color: var(--color-muted);
        border-bottom: 1px solid var(--color-rule);
      }
      .tab__summary::-webkit-details-marker {
        display: none;
      }
      .tab[open] > .tab__summary {
        color: var(--color-ink);
      }
      .tab__panel {
        padding: 1.75rem 0 0.5rem;
      }

      /* JS-enhanced: a horizontal tab bar. details get display:contents so
         their summaries flow into row 1 and the open panel spans row 2. */
      .product-tabs[data-enhanced] {
        display: grid;
        grid-template-columns: repeat(var(--tab-count, 3), max-content);
        column-gap: clamp(28px, 6vw, 96px);
        row-gap: 0;
        align-items: end;
        border-top: 0;
      }
      .product-tabs[data-enhanced] > .tab {
        display: contents;
      }
      .product-tabs[data-enhanced] .tab__summary {
        grid-row: 1;
        margin-bottom: -1px;
        padding: 0 0 0.85rem;
        border-bottom: 2px solid transparent;
        white-space: nowrap;
      }
      .product-tabs[data-enhanced] .tab[open] > .tab__summary {
        border-bottom-color: var(--color-ink);
      }
      .product-tabs[data-enhanced] .tab__summary:focus-visible {
        outline: 2px solid var(--color-ink);
        outline-offset: 4px;
      }
      .product-tabs[data-enhanced] .tab__panel {
        grid-row: 2;
        grid-column: 1 / -1;
        border-top: 1px solid var(--color-rule);
        padding-top: 2.25rem;
      }
    </style>

    <script>
      for (const tabs of document.querySelectorAll<HTMLElement>(
        "[data-product-tabs]",
      )) {
        const items = Array.from(
          tabs.querySelectorAll<HTMLDetailsElement>("details.tab"),
        );
        const summaries = items.map(
          (d) => d.querySelector<HTMLElement>(".tab__summary")!,
        );
        tabs.style.setProperty("--tab-count", String(items.length));
        tabs.setAttribute("data-enhanced", "");

        const select = (index: number, focus = true) => {
          items.forEach((detail, i) => {
            detail.open = i === index;
            summaries[i].tabIndex = i === index ? 0 : -1;
          });
          if (focus) summaries[index].focus();
        };

        // start roving tabindex on whichever tab is open (first by default)
        select(Math.max(0, items.findIndex((d) => d.open)), false);

        summaries.forEach((summary, i) => {
          // clicking the active tab must not collapse it — keep one open
          summary.addEventListener("click", (event) => {
            event.preventDefault();
            select(i, false);
          });
          summary.addEventListener("keydown", (event) => {
            const last = items.length - 1;
            let next: number | null = null;
            if (event.key === "ArrowRight" || event.key === "ArrowDown")
              next = i === last ? 0 : i + 1;
            else if (event.key === "ArrowLeft" || event.key === "ArrowUp")
              next = i === 0 ? last : i - 1;
            else if (event.key === "Home") next = 0;
            else if (event.key === "End") next = last;
            if (next !== null) {
              event.preventDefault();
              select(next);
            }
          });
        });
      }
    </script>

    <SiteFooter instagramUrl={instagramUrl} />
  </main>
</BaseLayout>
