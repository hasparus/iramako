---
import { Image } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navbar from "../../components/Navbar.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import Section from "../../components/Section.astro";
import Button from "../../components/Button.astro";
import ContactIcon from "../../components/icons/Contact.astro";
import { products, categoryLabels } from "../../data/products";

export function getStaticPaths() {
  return products.map((product) => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

const { product } = Astro.props;
const instagramUrl = "https://www.instagram.com/ira.mako/";

const schema = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: `${product.name} — ${product.fullName}`,
  description: product.intro,
  image: new URL(product.image.src, Astro.site).toString(),
  brand: { "@type": "Brand", name: "iramako" },
  category: categoryLabels[product.category],
  offers: product.variants.map((variant) => ({
    "@type": "Offer",
    priceCurrency: "PLN",
    price: variant.price.match(/\d+/)?.[0],
    availability: "https://schema.org/InStock",
  })),
};
---

<BaseLayout
  title={`${product.name} | iramako`}
  description={product.intro}
  image={product.image.src}
  imageAlt={product.alt}
>
  <script
    type="application/ld+json"
    set:html={JSON.stringify(schema)}
    slot="head"
  />
  <main class="min-h-screen w-full">
    <Navbar instagramUrl={instagramUrl} />

    {/* hero */}
    <Section
      containerClass="grid grid-cols-1 items-center gap-8 py-10 sm:py-[clamp(44px,6vw,80px)] lg:grid-cols-[minmax(0,1fr)_minmax(0,1fr)] lg:gap-[clamp(32px,5vw,72px)]"
    >
      <figure
        class="relative isolate m-0 flex items-center justify-center"
        style={`--accent: ${product.accent}; --shadow-x: ${product.category === "hydrolaty" ? "26px" : "9px"}`}
      >
        {/* cast shadow: a flattened copy of the photo, same as the product list */}
        <Image
          aria-hidden="true"
          class="pointer-events-none absolute bottom-0 left-[calc(50%-var(--shadow-x))] -z-10 max-h-[380px] w-auto origin-bottom object-contain opacity-40 [filter:brightness(0)_blur(18px)] [mask-composite:intersect] [mask-image:linear-gradient(to_top,black_0%,transparent_48%),linear-gradient(to_right,transparent_47%,black_57%)] [transform:translateX(-50%)_scaleX(0.92)_scaleY(0.13)_skewX(-12deg)]"
          src={product.image}
          alt=""
          loading="eager"
        />
        <Image
          class="max-h-[380px] w-auto object-contain"
          src={product.image}
          alt={product.alt}
          loading="eager"
          fetchpriority="high"
          quality={95}
        />
      </figure>

      <div class="max-w-[560px]">
        <a
          href={`/#${product.category}`}
          class="text-sm uppercase tracking-[0.12em] text-muted hover:text-ink"
          >← {categoryLabels[product.category]}</a
        >
        <h1
          class="m-0 mt-4 text-[clamp(1.9rem,3.2vw,2.7rem)] font-bold leading-[1.05] tracking-[-0.04em] text-ink"
        >
          {product.name}
        </h1>
        <p class="mt-2 text-[clamp(1.05rem,1.2vw,1.2rem)] text-muted">
          {product.fullName}
        </p>
        <div class="mt-6 flex flex-wrap items-baseline gap-x-8 gap-y-2 text-ink">
          {
            product.variants.map((variant) => (
              <span class="text-[clamp(1.05rem,1.2vw,1.25rem)]">
                <span class="font-bold">{variant.price}</span>
                <span class="text-muted"> · {variant.size}</span>
              </span>
            ))
          }
        </div>
        <div class="mt-7">
          <Button href="mailto:centrala@iramako.pl" variant="primary">
            <ContactIcon slot="icon" />
            zamów / zapytaj
          </Button>
        </div>
      </div>
    </Section>

    {/* ARIA tabs. base (no-JS): tablist hidden, panels stack vertically so
        content stays readable and find-in-page works. JS turns it into a
        keyboard-navigable tab bar; all panels share one grid cell, so switching
        tabs never shifts the panel's position. */}
    <Section
      border="none"
      containerClass="py-12 sm:py-[clamp(48px,7vw,96px)]"
    >
      <div class="product-tabs" data-product-tabs>
        <div class="tablist" role="tablist" aria-label="Szczegóły produktu">
          <button
            class="tab-btn"
            role="tab"
            id="tab-opis"
            aria-controls="panel-opis"
            aria-selected="true"
          >
            opis
          </button>
          <button
            class="tab-btn"
            role="tab"
            id="tab-sklad"
            aria-controls="panel-sklad"
            aria-selected="false"
            tabindex="-1"
          >
            składniki
          </button>
          <button
            class="tab-btn"
            role="tab"
            id="tab-opr"
            aria-controls="panel-opr"
            aria-selected="false"
            tabindex="-1"
          >
            o produkcie
          </button>
        </div>

        <div
          class="tab-panel max-w-[760px] text-[clamp(1.05rem,1.2vw,1.22rem)] leading-relaxed text-muted"
          role="tabpanel"
          id="panel-opis"
          aria-labelledby="tab-opis"
        >
          <p class="m-0">{product.intro}</p>
          <p class="mt-6 m-0">
            <span class="font-bold text-ink">Dla kogo? </span>{product.forWhom}
          </p>
          {
            product.scent && (
              <p class="mt-6 m-0">
                <span class="font-bold text-ink">Zapach. </span>
                {product.scent}
              </p>
            )
          }
          <h3 class="mt-10 mb-4 text-lg font-bold text-ink">Sposób użycia</h3>
          <ol class="m-0 flex list-decimal flex-col gap-2 pl-5">
            {product.usage.map((step) => <li>{step}</li>)}
          </ol>
        </div>

        <div
          class="tab-panel"
          role="tabpanel"
          id="panel-sklad"
          aria-labelledby="tab-sklad"
        >
          <dl class="m-0">
            {
              product.ingredients.map((ingredient) => (
                <div class="grid grid-cols-1 gap-x-8 gap-y-1 border-b border-rule py-3 last:border-b-0 sm:grid-cols-[minmax(0,220px)_minmax(0,1fr)]">
                  <dt class="font-medium text-ink">{ingredient.name}</dt>
                  <dd class="m-0 text-[clamp(1rem,1.1vw,1.12rem)] leading-relaxed text-muted">
                    {ingredient.description}
                  </dd>
                </div>
              ))
            }
          </dl>
          <p class="mt-6 text-sm leading-relaxed text-muted">
            <span class="font-bold text-ink">Składniki / Ingredients: </span>
            {product.inci}
          </p>
        </div>

        <div
          class="tab-panel max-w-[760px] text-[clamp(1.05rem,1.2vw,1.22rem)] leading-relaxed text-muted"
          role="tabpanel"
          id="panel-opr"
          aria-labelledby="tab-opr"
        >
          {
            product.research.length > 0 && (
              <p class="m-0">
                <span class="font-bold text-ink">Badania. </span>
                {product.research.join(" ")}
              </p>
            )
          }
          <p class="mt-6 m-0">
            <span class="font-bold text-ink">Opakowanie. </span>
            {product.packaging}
          </p>
          <p class="mt-6 m-0">
            <span class="font-bold text-ink">Ostrzeżenia. </span>
            {product.warnings}
          </p>
          <p class="mt-6 m-0">
            <span class="font-bold text-ink">Cena. </span>
            {product.variants.map((v) => `${v.size} — ${v.price}`).join(" · ")}
          </p>
        </div>
      </div>
    </Section>

    <style>
      /* base (no-JS): hide the inert tablist, stack panels vertically */
      .product-tabs {
        border-top: 1px solid var(--color-rule);
      }
      .tablist {
        display: none;
      }
      .tab-panel {
        padding: 1.75rem 0 0.5rem;
        border-bottom: 1px solid var(--color-rule);
      }

      /* JS-enhanced: real tab bar + panels stacked in one grid cell */
      .product-tabs[data-enhanced] {
        display: grid;
        grid-template-columns: minmax(0, 1fr);
        border-top: 0;
      }
      .product-tabs[data-enhanced] .tablist {
        display: flex;
        flex-wrap: wrap;
        column-gap: clamp(28px, 6vw, 96px);
        border-bottom: 1px solid var(--color-rule);
      }
      .tab-btn {
        appearance: none;
        background: none;
        border: 0;
        border-bottom: 2px solid transparent;
        margin-bottom: -1px;
        padding: 0 0 0.85rem;
        cursor: pointer;
        white-space: nowrap;
        font: inherit;
        font-weight: 700;
        font-size: clamp(1.05rem, 1.4vw, 1.3rem);
        letter-spacing: -0.02em;
        color: var(--color-muted);
      }
      .tab-btn:hover {
        color: var(--color-ink);
      }
      .tab-btn[aria-selected="true"] {
        color: var(--color-ink);
        border-bottom-color: var(--color-ink);
      }
      .tab-btn:focus-visible {
        outline: 2px solid var(--color-ink);
        outline-offset: 4px;
      }
      /* every panel occupies the same cell → no shift when switching */
      .product-tabs[data-enhanced] .tab-panel {
        grid-row: 2;
        grid-column: 1;
        min-width: 0;
        border-bottom: 0;
        padding: 2.25rem 0 0;
      }
      /* fully hide inactive panels, but let hidden="until-found" fall through
         to the UA's content-visibility so Ctrl+F can still match inside them */
      .product-tabs[data-enhanced] .tab-panel[hidden]:not([hidden="until-found"]) {
        display: none;
      }
    </style>

    <script>
      for (const tabs of document.querySelectorAll<HTMLElement>(
        "[data-product-tabs]",
      )) {
        const buttons = Array.from(
          tabs.querySelectorAll<HTMLButtonElement>('[role="tab"]'),
        );
        const panels = buttons.map(
          (b) => document.getElementById(b.getAttribute("aria-controls")!)!,
        );
        tabs.setAttribute("data-enhanced", "");

        const select = (index: number, focus = true) => {
          buttons.forEach((button, i) => {
            const on = i === index;
            button.setAttribute("aria-selected", String(on));
            button.tabIndex = on ? 0 : -1;
            // hidden="until-found" keeps inactive panels findable by Ctrl+F
            if (on) panels[i].removeAttribute("hidden");
            else panels[i].setAttribute("hidden", "until-found");
          });
          if (focus) buttons[index].focus();
        };

        select(0, false);

        buttons.forEach((button, i) => {
          // Ctrl+F into a hidden panel: activate its tab, then the browser scrolls to it
          panels[i].addEventListener("beforematch", () => select(i, false));
          button.addEventListener("click", () => select(i, false));
          button.addEventListener("keydown", (event) => {
            const last = buttons.length - 1;
            let next: number | null = null;
            if (event.key === "ArrowRight" || event.key === "ArrowDown")
              next = i === last ? 0 : i + 1;
            else if (event.key === "ArrowLeft" || event.key === "ArrowUp")
              next = i === 0 ? last : i - 1;
            else if (event.key === "Home") next = 0;
            else if (event.key === "End") next = last;
            if (next !== null) {
              event.preventDefault();
              select(next);
            }
          });
        });
      }
    </script>

    <SiteFooter instagramUrl={instagramUrl} />
  </main>
</BaseLayout>
