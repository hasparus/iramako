---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/Button.astro";
import FormulaCard from "../components/FormulaCard.astro";
import Section from "../components/Section.astro";
import SiteFooter from "../components/SiteFooter.astro";
import Navbar from "../components/Navbar.astro";
import heroImage from "../assets/4 słoiki_miękki cień.png";
import { products, productsByCategory } from "../data/products";

const instagramUrl = "https://www.instagram.com/ira.mako/";

// one grid, filtered by chips — keeps the per-category nav anchors working
// (chip ids match #olejki/#kremy/… hashes) without the long scroll
const productFilters = [
  { id: "all", label: "wszystkie" },
  ...productsByCategory.map((g) => ({ id: g.category, label: g.label })),
];
const allProducts = productsByCategory.flatMap((g) => g.items);

const productListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  itemListElement: products.map((product, index) => ({
    "@type": "ListItem",
    position: index + 1,
    item: {
      "@type": "Product",
      name: product.name,
      description: product.intro.split(". ")[0] + ".",
      image: new URL(product.image.src, Astro.site).toString(),
      brand: { "@type": "Brand", name: "iramako" },
    },
  })),
};
---

<BaseLayout>
  <script
    type="application/ld+json"
    set:html={JSON.stringify(productListSchema)}
    slot="head"
  />
  <main class="min-h-screen w-full">
    <Navbar instagramUrl={instagramUrl} />

    <Section
      containerClass="grid min-h-auto grid-cols-1 items-center gap-1 py-8 lg:grid-cols-[minmax(360px,.92fr)_minmax(0,1.08fr)] lg:gap-[clamp(42px,7vw,112px)]"
    >
      <div class="max-w-165 md:max-lg:max-w-full">
        <h1 class="m-0 text-ink">
          <span
            class="block text-3xl font-bold leading-[1.02] tracking-[-0.04em]"
            >proste formuły. świadoma pielęgnacja</span
          >
          <span
            class="mt-2 block text-2xl font-medium leading-[1.1] tracking-[-0.03em] text-muted"
            >tworzone we Wrocławiu</span
          >
        </h1>
        <div class="mt-10 flex flex-wrap gap-3 sm:mt-16">
          <Button href="#produkty" variant="primary"> zobacz produkty </Button>
        </div>
      </div>

      <figure class="m-0">
        <Image
          class="max-h-160 max-w-none object-contain object-bottom mix-blend-multiply lg:ml-[-6.005%] w-full"
          src={heroImage}
          alt="Trzy słoiki kremów iramako na jasnym tle"
          loading="eager"
          fetchpriority="high"
          quality={95}
        />
      </figure>
    </Section>

    <Section
      id="skladniki"
      aria-label="składniki"
      containerClass="grid grid-cols-1 lg:grid-cols-3"
    >
      <FormulaCard
        number="01"
        name="róża"
        description="hydrolat z róży pomaga skórze wrócić do komfortu."
      />
      <FormulaCard
        number="02"
        name="malina"
        description="olej z nasion malin zostawia miękkość bez ciężaru."
      />
      <FormulaCard
        number="03"
        name="komfort"
        description="kremowa formuła na poranek i wieczór."
      />
    </Section>

    <Section
      id="produkty"
      aria-label="produkty"
      containerClass="py-16 sm:py-[clamp(84px,10vw,118px)]"
    >
      <h2
        class="m-0 max-w-[520px] text-3xl font-bold leading-[0.98] tracking-[-0.04em] text-ink"
      >
        kosmetyki bez nadmiaru
      </h2>

      <div
        data-product-filters
        role="toolbar"
        aria-label="filtruj produkty"
        class="mt-8 flex flex-wrap gap-x-2 gap-y-1 sm:mt-10"
      >
        {productFilters.map((f, i) => (
          <button
            type="button"
            data-filter={f.id}
            aria-pressed={i === 0 ? "true" : "false"}
            tabindex={i === 0 ? "0" : "-1"}
            class="cursor-pointer px-3 py-1 text-sm lowercase tracking-[0.02em] text-muted decoration-1 underline-offset-[6px] transition-colors hover:text-ink aria-pressed:text-ink aria-pressed:underline"
          >
            {f.label}
          </button>
        ))}
      </div>

      <ul class="mt-10 grid list-none grid-cols-2 gap-x-[clamp(4px,3vw,36px)] gap-y-8 p-0 sm:mt-12 lg:grid-cols-4">
        {allProducts.map((product) => (
          <li
            data-category={product.category}
            class="p-2 has-[a:focus-visible]:outline-2 has-[a:focus-visible]:outline-offset-2 has-[a:focus-visible]:outline-black"
          >
            <a
              href={`/produkty/${product.slug}`}
              class="group block outline-none"
              style={`--accent: ${product.accent}`}
            >
              <figure class="m-0 flex h-40 items-center justify-center overflow-hidden sm:h-48">
                <Image
                  class="max-h-full w-auto object-contain transition-transform duration-500 ease-out group-hover:scale-[1.06]"
                  src={product.image}
                  alt={product.alt}
                  loading="lazy"
                />
              </figure>
              <h4 class="mt-4 text-[clamp(1.02rem,1.3vw,1.22rem)] font-medium text-ink transition-colors group-hover:text-(--accent)">
                {product.name}
              </h4>
              <p class="mt-1 text-sm text-muted">{product.fullName}</p>
              <span
                aria-hidden="true"
                class="mt-2 flex items-center gap-1 text-sm font-medium text-(--accent) opacity-0 transition-all duration-300 group-hover:opacity-100 group-focus-visible:opacity-100"
              >
                dowiedz się więcej
                <svg
                  class="size-3.5 transition-transform duration-300 group-hover:translate-x-1"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  aria-hidden="true"
                >
                  <path d="M5 12h14M13 6l6 6-6 6" />
                </svg>
              </span>
            </a>
            {product.variants.length > 1 ? (
              <div data-size-picker class="mt-3 flex items-center gap-3">
                <div
                  role="radiogroup"
                  aria-label={`pojemność — ${product.name}`}
                  class="inline-flex border border-rule has-[:focus-visible]:outline-2 has-[:focus-visible]:outline-offset-2 has-[:focus-visible]:outline-black"
                >
                  {product.variants.map((variant, i) => (
                    <button
                      type="button"
                      role="radio"
                      data-size-option
                      data-price={variant.price}
                      aria-checked={i === 0 ? "true" : "false"}
                      tabindex={i === 0 ? "0" : "-1"}
                      class="cursor-pointer px-3 py-1.5 text-sm text-muted outline-none hover:text-ink aria-checked:bg-ink aria-checked:text-paper"
                    >
                      {variant.size}
                    </button>
                  ))}
                </div>
                <span data-size-price class="font-bold text-ink">
                  {product.variants[0].price}
                </span>
              </div>
            ) : (
              <p class="mt-3 text-ink">
                <span class="font-bold">{product.variants[0].price}</span>
                <span class="text-muted">
                  {" "}
                  · {product.variants[0].size}
                </span>
              </p>
            )}
          </li>
        ))}
      </ul>
    </Section>

    <script>
      // size radiogroup: arrow-key nav + roving tabindex, reflect price
      for (const picker of document.querySelectorAll("[data-size-picker]")) {
        const options = [
          ...picker.querySelectorAll<HTMLButtonElement>("[data-size-option]"),
        ];
        const price = picker.querySelector("[data-size-price]");

        const select = (i: number, focus = false) => {
          options.forEach((o, j) => {
            const on = i === j;
            o.setAttribute("aria-checked", String(on));
            o.tabIndex = on ? 0 : -1;
          });
          if (price) price.textContent = options[i].dataset.price ?? "";
          if (focus) options[i].focus();
        };

        options.forEach((option, i) => {
          option.addEventListener("click", () => select(i));
          option.addEventListener("keydown", (e) => {
            const step =
              e.key === "ArrowRight" || e.key === "ArrowDown"
                ? 1
                : e.key === "ArrowLeft" || e.key === "ArrowUp"
                  ? -1
                  : 0;
            if (!step) return;
            e.preventDefault();
            select((i + step + options.length) % options.length, true);
          });
        });
      }

      // product filters: one grid, chips toggle visibility. Category nav
      // anchors (#kremy, #olejki, …) drive the same filter via the hash.
      const filterBar = document.querySelector("[data-product-filters]");
      if (filterBar) {
        const chips = [
          ...filterBar.querySelectorAll<HTMLButtonElement>("[data-filter]"),
        ];
        const items = [
          ...document.querySelectorAll<HTMLLIElement>("[data-category]"),
        ];

        const roving = (active: number) =>
          chips.forEach((c, j) => (c.tabIndex = j === active ? 0 : -1));

        const apply = (id: string) => {
          chips.forEach((chip, j) => {
            const on = chip.dataset.filter === id;
            chip.setAttribute("aria-pressed", String(on));
            if (on) roving(j);
          });
          for (const item of items)
            item.hidden = id !== "all" && item.dataset.category !== id;
        };

        const choose = (chip: HTMLButtonElement) => {
          const id = chip.dataset.filter!;
          apply(id);
          history.replaceState(null, "", id === "all" ? location.pathname : `#${id}`);
        };

        chips.forEach((chip, i) => {
          chip.addEventListener("click", () => choose(chip));
          chip.addEventListener("keydown", (e) => {
            let next = -1;
            if (e.key === "ArrowRight" || e.key === "ArrowDown")
              next = (i + 1) % chips.length;
            else if (e.key === "ArrowLeft" || e.key === "ArrowUp")
              next = (i - 1 + chips.length) % chips.length;
            else if (e.key === "Home") next = 0;
            else if (e.key === "End") next = chips.length - 1;
            else return;
            e.preventDefault();
            choose(chips[next]); // arrows move focus AND apply the filter
            chips[next].focus();
          });
        });

        const fromHash = (scroll = false) => {
          const hash = location.hash.slice(1);
          const match = chips.some((c) => c.dataset.filter === hash);
          apply(match ? hash : "all");
          // no element has id="kremy" anymore — bring the grid into view ourselves
          if (scroll && match)
            document.getElementById("produkty")?.scrollIntoView();
        };
        window.addEventListener("hashchange", () => fromHash(true));
        fromHash(true);
      }
    </script>

    <Section containerClass="py-20">
      <p
        class="m-0 w-full font-semibold tracking-[0.001em] text-[clamp(2.1rem,4vw,4.6rem)] leading-[1.05] text-ink"
      >
        <span class="block">Naturalne składniki.</span>
        <span class="block">Starannie dobrane olejki roślinne.</span>
        <span class="block">Proste formuły.</span>
        <span class="block">Przyjemność codziennej pielęgnacji.</span>
      </p>
    </Section>

    <SiteFooter instagramUrl={instagramUrl} />
  </main>
</BaseLayout>
