---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/Button.astro";
import FormulaCard from "../components/FormulaCard.astro";
import Section from "../components/Section.astro";
import SiteFooter from "../components/SiteFooter.astro";
import Navbar from "../components/Navbar.astro";
import heroImage from "../assets/iramako-hero-3-sloiki-baked.png";
import { products, productsByCategory } from "../data/products";

const instagramUrl = "https://www.instagram.com/ira.mako/";

const productListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  itemListElement: products.map((product, index) => ({
    "@type": "ListItem",
    position: index + 1,
    item: {
      "@type": "Product",
      name: product.name,
      description: product.intro.split(". ")[0] + ".",
      image: new URL(product.image.src, Astro.site).toString(),
      brand: { "@type": "Brand", name: "iramako" },
    },
  })),
};
---

<BaseLayout>
  <script
    type="application/ld+json"
    set:html={JSON.stringify(productListSchema)}
    slot="head"
  />
  <main class="min-h-screen w-full">
    <Navbar instagramUrl={instagramUrl} />

    <Section
      containerClass="grid min-h-auto grid-cols-1 items-center gap-11 py-14 sm:py-[clamp(72px,8vw,130px)] lg:min-h-[calc(100vh-156px)] lg:grid-cols-[minmax(360px,.92fr)_minmax(0,1.08fr)] lg:gap-[clamp(42px,7vw,112px)] lg:pb-[clamp(64px,7vw,98px)]"
    >
      <div class="max-w-165 md:max-lg:max-w-full">
        <h1 class="m-0 text-ink">
          <span
            class="block text-[clamp(2.4rem,8vw,5rem)] font-bold leading-[1.02] tracking-[-0.04em]"
            >proste formuły. świadoma pielęgnacja</span
          >
          <span
            class="mt-2 block text-[clamp(1.4rem,4vw,2.4rem)] font-medium leading-[1.1] tracking-[-0.03em] text-muted"
            >tworzone we Wrocławiu</span
          >
        </h1>
        <div class="mt-10 flex flex-wrap gap-3 sm:mt-16">
          <Button href="#produkty" variant="primary">
            poznaj nasze produkty
          </Button>
        </div>
      </div>

      <figure class="m-0">
        <Image
          class="max-h-160 max-w-none object-contain object-bottom mix-blend-multiply lg:ml-[-6.005%] lg:p-[18.337%_0_2.731%_0] lg:w-[105.856%] w-full"
          src={heroImage}
          alt="Trzy słoiki kremów iramako na jasnym tle"
          loading="eager"
          fetchpriority="high"
          quality={95}
        />
      </figure>
    </Section>

    <Section
      id="skladniki"
      aria-label="składniki"
      containerClass="grid grid-cols-1 lg:grid-cols-3"
    >
      <FormulaCard
        number="01"
        name="róża"
        description="hydrolat z róży pomaga skórze wrócić do komfortu."
      />
      <FormulaCard
        number="02"
        name="malina"
        description="olej z nasion malin zostawia miękkość bez ciężaru."
      />
      <FormulaCard
        number="03"
        name="komfort"
        description="kremowa formuła na poranek i wieczór."
      />
    </Section>

    <Section
      id="produkty"
      aria-label="produkty"
      containerClass="py-20 sm:py-[clamp(84px,10vw,150px)]"
    >
      <h2
        class="m-0 max-w-[520px] text-[clamp(3rem,5vw,5.4rem)] font-bold leading-[0.98] tracking-[-0.04em] text-ink"
      >
        Kosmetyki bez nadmiaru.
      </h2>

      {
        productsByCategory.map((group) => (
          <div id={group.category} class="mt-16 scroll-mt-24 sm:mt-20">
            <h3 class="m-0 mb-8 border-b border-rule pb-4 text-sm font-bold uppercase tracking-[0.14em] text-muted">
              {group.label}
            </h3>
            <ul class="m-0 grid list-none grid-cols-2 gap-x-[clamp(20px,3vw,52px)] gap-y-12 p-0 lg:grid-cols-4">
              {group.items.map((product) => (
                <li>
                  <a
                    href={`/produkty/${product.slug}`}
                    class="group block"
                    style={`--accent: ${product.accent}`}
                  >
                    <figure class="m-0 flex h-40 items-center justify-center sm:h-48">
                      <Image
                        class="max-h-full w-auto object-contain"
                        src={product.image}
                        alt={product.alt}
                        loading="lazy"
                      />
                    </figure>
                    <h4 class="mt-4 text-[clamp(1.02rem,1.3vw,1.22rem)] font-medium text-ink group-hover:text-(--accent)">
                      {product.name}
                    </h4>
                    <p class="mt-1 text-sm text-muted">{product.fullName}</p>
                  </a>
                  {product.variants.length > 1 ? (
                    <div data-size-picker class="mt-3 flex items-center gap-3">
                      <div class="relative">
                        <select
                          aria-label={`rozmiar — ${product.name}`}
                          data-size-select
                          class="cursor-pointer appearance-none rounded-none border border-rule bg-transparent py-1.5 pl-3 pr-8 text-sm text-ink hover:border-ink focus:border-ink focus:outline-none"
                        >
                          {product.variants.map((variant) => (
                            <option value={variant.price}>{variant.size}</option>
                          ))}
                        </select>
                        <svg
                          class="pointer-events-none absolute right-2.5 top-1/2 size-3.5 -translate-y-1/2 text-muted"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="1.5"
                          aria-hidden="true"
                        >
                          <path d="m6 9 6 6 6-6" />
                        </svg>
                      </div>
                      <span data-size-price class="font-bold text-ink">
                        {product.variants[0].price}
                      </span>
                    </div>
                  ) : (
                    <p class="mt-3 text-ink">
                      <span class="font-bold">{product.variants[0].price}</span>
                      <span class="text-muted"> · {product.variants[0].size}</span>
                    </p>
                  )}
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </Section>

    <script>
      // size select: reflect the chosen variant's price next to it
      for (const select of document.querySelectorAll<HTMLSelectElement>(
        "[data-size-select]",
      )) {
        const price = select
          .closest("[data-size-picker]")
          ?.querySelector("[data-size-price]");
        if (price) {
          select.addEventListener("change", () => {
            price.textContent = select.value;
          });
        }
      }
    </script>

    <Section containerClass="py-20 sm:py-[clamp(84px,12vw,180px)]">
      <p
        class="m-0 w-full max-w-[970px] text-[clamp(2.1rem,4vw,4.6rem)] font-medium leading-[1.05] tracking-[-0.04em] text-ink"
      >
        <span class="block">Naturalne składniki.</span>
        <span class="block">Starannie dobrane olejki roślinne.</span>
        <span class="block">Proste formuły.</span>
        <span class="block">Przyjemność codziennej pielęgnacji.</span>
      </p>
    </Section>

    <SiteFooter instagramUrl={instagramUrl} />
  </main>
</BaseLayout>
