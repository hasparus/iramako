---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/Button.astro";
import FormulaCard from "../components/FormulaCard.astro";
import Section from "../components/Section.astro";
import SiteFooter from "../components/SiteFooter.astro";
import Navbar from "../components/Navbar.astro";
import heroImage from "../assets/4 słoiki_miękki cień.png";
import { products, productsByCategory } from "../data/products";
import placeholder from "../assets/products/placeholder.webp";

const instagramUrl = "https://www.instagram.com/ira.mako/";

const productListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  itemListElement: products.map((product, index) => ({
    "@type": "ListItem",
    position: index + 1,
    item: {
      "@type": "Product",
      name: product.name,
      description: product.intro.split(". ")[0] + ".",
      // ponytail: skip placeholder — no real photo to put in structured data
      ...(product.image.src !== placeholder.src && {
        image: new URL(product.image.src, Astro.site).toString(),
      }),
      brand: { "@type": "Brand", name: "iramako" },
    },
  })),
};
---

<BaseLayout>
  <script
    type="application/ld+json"
    set:html={JSON.stringify(productListSchema)}
    slot="head"
  />
  <main class="min-h-screen w-full">
    <Navbar instagramUrl={instagramUrl} />

    <Section
      containerClass="grid min-h-auto grid-cols-1 items-center gap-1 py-8 lg:grid-cols-[minmax(360px,.92fr)_minmax(0,1.08fr)] lg:gap-[clamp(42px,7vw,112px)]"
    >
      <div class="max-w-165 md:max-lg:max-w-full">
        <h1 class="m-0 text-ink">
          <span
            class="block text-3xl font-bold leading-[1.02] tracking-[-0.04em]"
            >proste formuły. świadoma pielęgnacja</span
          >
          <span
            class="mt-2 block text-2xl font-medium leading-[1.1] tracking-[-0.03em] text-muted"
            >tworzone we Wrocławiu</span
          >
        </h1>
        <div class="mt-10 flex flex-wrap gap-3 sm:mt-16">
          <Button href="#produkty" variant="primary"> zobacz produkty </Button>
        </div>
      </div>

      <figure class="m-0">
        <Image
          class="max-h-160 max-w-none object-contain object-bottom lg:ml-[-6.005%] w-full"
          src={heroImage}
          alt="Trzy słoiki kremów iramako na jasnym tle"
          loading="eager"
          fetchpriority="high"
          quality={95}
        />
      </figure>
    </Section>

    <Section
      id="skladniki"
      aria-label="składniki"
      containerClass="grid grid-cols-1 lg:grid-cols-3"
    >
      <FormulaCard
        number="01"
        name="róża"
        description="hydrolat z róży pomaga skórze wrócić do komfortu."
      />
      <FormulaCard
        number="02"
        name="malina"
        description="olej z nasion malin zostawia miękkość bez ciężaru."
      />
      <FormulaCard
        number="03"
        name="komfort"
        description="kremowa formuła na poranek i wieczór."
      />
    </Section>

    <Section
      id="produkty"
      aria-label="produkty"
      containerClass="py-16 sm:py-[clamp(84px,10vw,118px)]"
    >
      <h2
        class="m-0 text-[clamp(1.75rem,3.3vw,3.7rem)] font-bold leading-[0.98] tracking-[-0.04em] text-ink"
      >
        kosmetyki bez nadmiaru
      </h2>

      {
        productsByCategory.map((group) => (
          <div id={group.category} class="mt-16 scroll-mt-24 sm:mt-20">
            <h3 class="m-0 mb-8 border-b border-rule pb-4 text-sm font-bold uppercase tracking-[0.14em] text-muted">
              {group.label}
            </h3>
            <ul class="m-0 grid list-none grid-cols-2 gap-x-[clamp(4px,3vw,36px)] gap-y-8 p-0 lg:grid-cols-4">
              {group.items.map((product) => (
                <li
                  style={`--accent: ${product.accent}; --shadow-x: ${product.category === "hydrolaty" ? "14px" : "0px"}`}
                  class="group flex flex-col p-2 has-[a:focus-visible]:outline-2 has-[a:focus-visible]:outline-offset-2 has-[a:focus-visible]:outline-black"
                >
                  <a
                    href={`/produkty/${product.slug}`}
                    class="block outline-none"
                  >
                    <figure class="relative isolate m-0 flex h-40 items-center justify-center sm:h-48">
                      {/* cast shadow: a second copy of the photo, flattened onto
                          the "floor" and skewed up-right as if lit from lower-left.
                          blur on the wrapper (after the mask) softens its edge.
                          skipped for the placeholder — no real photo to cast. */}
                      {product.image.src !== placeholder.src && (
                        <div
                          aria-hidden="true"
                          class="pointer-events-none absolute bottom-1 left-[calc(50%-var(--shadow-x))] -z-10 blur-xs"
                        >
                          <Image
                            class="max-h-40 w-auto origin-bottom object-contain filter-[brightness(0)_blur(12px)] mask-intersect mask-[linear-gradient(to_top,black_0%,transparent_48%),linear-gradient(to_right,transparent_47%,black_57%)] transform-[translateX(-50%)_scaleX(0.94)_scaleY(0.29)_skewX(-22deg)] transition-[opacity,transform] duration-500 ease-out group-hover:opacity-60 sm:max-h-48"
                            src={product.image}
                            alt=""
                            loading="lazy"
                          />
                        </div>
                      )}
                      <Image
                        class="max-h-full w-auto object-contain"
                        src={product.image}
                        alt={product.alt}
                        loading="lazy"
                      />
                    </figure>
                    <h4 class="mt-4 text-[clamp(1.02rem,1.3vw,1.22rem)] font-medium text-ink transition-colors group-hover:text-(--accent)">
                      {product.name}
                    </h4>
                    <p class="mt-1 text-sm text-muted">{product.fullName}</p>
                  </a>
                  {product.variants.length > 1 ? (
                    <div data-size-picker class="mt-3 flex items-center gap-3">
                      <div
                        role="radiogroup"
                        aria-label={`pojemność — ${product.name}`}
                        class="inline-flex border border-rule has-focus-visible:outline-2 has-focus-visible:outline-offset-2 has-focus-visible:outline-black"
                      >
                        {product.variants.map((variant, i) => (
                          <button
                            type="button"
                            role="radio"
                            data-size-option
                            data-price={variant.price}
                            aria-checked={i === 0 ? "true" : "false"}
                            tabindex={i === 0 ? "0" : "-1"}
                            class="cursor-pointer px-3 py-1.5 text-sm text-muted outline-none hover:text-ink aria-checked:bg-ink aria-checked:text-paper"
                          >
                            {variant.size}
                          </button>
                        ))}
                      </div>
                      <span data-size-price class="font-bold text-ink">
                        {product.variants[0].price}
                      </span>
                    </div>
                  ) : (
                    <p class="mt-3 text-ink">
                      <span class="font-bold">{product.variants[0].price}</span>
                      <span class="text-muted">
                        {" "}
                        · {product.variants[0].size}
                      </span>
                    </p>
                  )}
                  <a
                    href={`/produkty/${product.slug}`}
                    class="mt-4 inline-flex w-fit items-center gap-1 text-sm font-medium leading-none text-(--accent) opacity-0 outline-none transition-all duration-300 hover:underline hover:underline-offset-4 group-hover:opacity-100 group-has-[a:focus-visible]:opacity-100"
                  >
                    dowiedz się więcej
                    <svg
                      class="size-4 shrink-0 translate-y-[0.5px] transition-transform duration-300 group-hover:translate-x-1"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.5"
                      aria-hidden="true"
                    >
                      <path d="M5 12h14M13 6l6 6-6 6" />
                    </svg>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </Section>

    <script>
      // size radiogroup: arrow-key nav + roving tabindex, reflect price
      for (const picker of document.querySelectorAll("[data-size-picker]")) {
        const options = [
          ...picker.querySelectorAll<HTMLButtonElement>("[data-size-option]"),
        ];
        const price = picker.querySelector("[data-size-price]");

        const select = (i: number, focus = false) => {
          options.forEach((o, j) => {
            const on = i === j;
            o.setAttribute("aria-checked", String(on));
            o.tabIndex = on ? 0 : -1;
          });
          if (price) price.textContent = options[i].dataset.price ?? "";
          if (focus) options[i].focus();
        };

        options.forEach((option, i) => {
          option.addEventListener("click", () => select(i));
          option.addEventListener("keydown", (e) => {
            const step =
              e.key === "ArrowRight" || e.key === "ArrowDown"
                ? 1
                : e.key === "ArrowLeft" || e.key === "ArrowUp"
                  ? -1
                  : 0;
            if (!step) return;
            e.preventDefault();
            select((i + step + options.length) % options.length, true);
          });
        });
      }
    </script>

    <Section containerClass="py-20" border="none">
      <p
        class="m-0 mt-2 w-full font-semibold tracking-[0.001em] text-[clamp(1.75rem,3.3vw,3.7rem)] leading-[1.05] text-ink"
      >
        <span class="block">Naturalne składniki.</span>
        <span class="block">Starannie dobrane olejki roślinne.</span>
        <span class="block">Proste formuły.</span>
        <span class="block">Przyjemność codziennej pielęgnacji.</span>
      </p>
    </Section>

    <SiteFooter instagramUrl={instagramUrl} />
  </main>
</BaseLayout>
