---
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/Button.astro";
import Eyebrow from "../components/Eyebrow.astro";
import ContactIcon from "../components/icons/Contact.astro";
import InstagramIcon from "../components/icons/Instagram.astro";
import Section from "../components/Section.astro";
import SiteFooter from "../components/SiteFooter.astro";
import Navbar from "../components/Navbar.astro";

const heroImage = "/assets/iramako-hero-3-sloiki.png";
const instagramUrl = "https://www.instagram.com/ira.mako/";

const formulas = [
  {
    number: "01",
    name: "róża",
    copy: "hydrolat z róży pomaga skórze wrócić do komfortu.",
  },
  {
    number: "02",
    name: "malina",
    copy: "olej z nasion malin zostawia miękkość bez ciężaru.",
  },
  {
    number: "03",
    name: "komfort",
    copy: "kremowa formuła na poranek i wieczór.",
  },
];

const products = [
  {
    name: "Krem Róża + Malina z retinolem roślinnym 2%",
    size: "30 i 60 ml",
    description: "odżywiający krem z roślinnym retinolem, różą damasceńską i olejem z nasion malin",
  },
  {
    name: "Krem Róża + Malina nawilżający z wit. B3",
    size: "30 i 60 ml",
    description: "nawilżający krem z witaminą B3 i mocznikiem do codziennego komfortu skóry",
  },
  {
    name: "Glinka biała kaolinowa",
    size: "40 g",
    description: "mineralna pielęgnacja do mycia twarzy i robienia maseczek",
  },
  {
    name: "Hydrolat różany",
    size: "100 ml",
    description: "naturalna mgiełka tonizująca z płatków róży damasceńskiej",
  },
];
---

<BaseLayout>
  <main class="min-h-screen w-full">
    <Navbar instagramUrl={instagramUrl} />

    <Section
      containerClass="grid min-h-auto grid-cols-1 items-center gap-11 py-14 sm:py-[clamp(72px,8vw,130px)] lg:min-h-[calc(100vh-156px)] lg:grid-cols-[minmax(360px,.92fr)_minmax(0,1.08fr)] lg:gap-[clamp(42px,7vw,112px)] lg:pb-[clamp(64px,7vw,98px)]"
    >
      <div class="max-w-[660px]">
        <Eyebrow>naturalnie i lokalnie</Eyebrow>
        <h1
          class="m-0 text-[clamp(3.25rem,14vw,7.75rem)] font-bold leading-[0.98] tracking-[-0.04em] text-ink lg:text-[clamp(4rem,7.2vw,7.75rem)]"
        >
          Naturalne kremy dla skóry.
        </h1>
        <div class="mt-10 flex flex-wrap gap-3 sm:mt-16">
          <Button href="#kontakt" variant="primary">
            <ContactIcon slot="icon" />
            kontakt
          </Button>
          <Button href={instagramUrl} target="_blank" rel="noreferrer">
            <InstagramIcon slot="icon" />
            instagram
          </Button>
        </div>
      </div>

      <figure class="m-0">
        <img
          class="mx-auto max-h-[640px] w-full object-contain object-bottom mix-blend-multiply"
          src={heroImage}
          alt="Trzy słoiki kremów iramako na jasnym tle"
        />
      </figure>
    </Section>

    <Section id="skladniki" aria-label="składniki" containerClass="grid grid-cols-1 lg:grid-cols-3">
      {
        formulas.map((formula, index) => (
          <article
            class:list={[
              "border-b border-rule py-8 lg:min-h-[220px] lg:border-b-0 lg:py-[clamp(34px,4vw,58px)]",
              index !== formulas.length - 1 && "lg:border-r",
              index === 0 ? "lg:pr-[clamp(26px,4vw,78px)]" : "lg:px-[clamp(26px,4vw,78px)]",
              index === formulas.length - 1 && "border-b-0 lg:pr-0",
            ]}
          >
            <p class="mb-6 text-[0.92rem] font-bold leading-none text-ink">{formula.number}</p>
            <h2 class="mb-4 text-[clamp(2rem,3vw,3.1rem)] font-bold leading-[0.95] tracking-[-0.04em] text-ink">
              {formula.name}
            </h2>
            <p class="m-0 max-w-[260px] text-[clamp(1rem,1.1vw,1.18rem)] leading-[1.45] text-muted">{formula.copy}</p>
          </article>
        ))
      }
    </Section>

    <Section
      id="kosmetyki"
      aria-label="kosmetyki"
      containerClass="grid grid-cols-1 gap-11 py-20 sm:py-[clamp(84px,10vw,150px)] lg:grid-cols-[minmax(260px,.44fr)_minmax(0,1fr)] lg:gap-[clamp(48px,8vw,116px)]"
    >
      <div class="max-w-[520px]">
        <Eyebrow>codzienny rytuał</Eyebrow>
        <h2 class="m-0 text-[clamp(3rem,5vw,5.4rem)] font-bold leading-[0.98] tracking-[-0.04em] text-ink">
          Kosmetyki bez nadmiaru.
        </h2>
      </div>

      <div class="border-t border-rule">
        {
          products.map((product) => (
            <article class="grid grid-cols-1 gap-2 border-b border-rule py-6 text-[clamp(1rem,1.2vw,1.22rem)] leading-snug text-ink sm:grid-cols-[minmax(220px,.42fr)_minmax(100px,.18fr)_minmax(0,1fr)] sm:gap-[clamp(24px,4vw,64px)]">
              <h3 class="m-0 font-medium">{product.name}</h3>
              <p class="m-0 text-muted">{product.size}</p>
              <p class="m-0 text-muted">{product.description}</p>
            </article>
          ))
        }
      </div>
    </Section>

    <Section containerClass="py-20 sm:py-[clamp(84px,12vw,180px)]">
      <p class="m-0 w-full max-w-[970px] text-[clamp(2.1rem,4vw,4.6rem)] font-medium leading-[1.05] tracking-[-0.04em] text-ink">
        Naturalne oleje, hydrolat z róży damasceńskiej i proste składy. iramako robi pielęgnację spokojną, codzienną,
        przyjemną w użyciu.
      </p>
    </Section>

    <SiteFooter instagramUrl={instagramUrl} />
  </main>
</BaseLayout>
