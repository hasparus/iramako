---
import Analytics from "@vercel/analytics/astro";
import SplashCursor from "../components/SplashCursor.astro";
import "../styles/global.css";

const {
  title = "iramako | kosmetyki naturalne",
  description = "Naturalne kosmetyki iramako: kremy, hydrolaty i mineralna pielęgnacja tworzona z myślą o codziennym komforcie skóry.",
} = Astro.props;
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/assets/iramako-logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Beth+Ellen&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <slot />

    <Analytics />
    <SplashCursor />
  </body>
</html>
