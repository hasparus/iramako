---
import Container from "./Container.astro";
import Logo from "./Logo.astro";
import NavLink from "./NavLink.astro";

interface Props {
  instagramUrl: string;
}

const { instagramUrl } = Astro.props;
---

<footer
  id="kontakt"
  class="relative z-40 border-t border-rule"
  aria-label="kontakt"
>
  <Container class="py-10 pb-5 sm:py-12 sm:pb-[clamp(24px,4vw,58px)]">
    <div
      class="flex flex-col gap-10 sm:flex-row sm:items-start sm:justify-between"
    >
      <div class="flex flex-col gap-8">
        <p class="font-bold leading-none text-ink text-2xl sm:text-3xl">
          iramako
        </p>
        <p
          class="font-medium leading-relaxed text-muted sm:text-lg"
        >
          <span class="block [text-box:trim-start_cap_alphabetic]"
            >sklep firmowy</span
          >
          <span class="block">pl. Uniwersytecki 7</span>
          <span class="block">50–137 Wrocław</span>
        </p>
        <div
          class="flex flex-col gap-3 text-[15px] font-medium leading-tight text-ink sm:flex-row sm:items-center sm:gap-[clamp(28px,5vw,72px)] sm:text-base"
        >
          <NavLink
            href={instagramUrl}
            target="_blank"
            rel="noreferrer"
            splash="kolko13">@ira.mako</NavLink
          >
          <NavLink href="mailto:centrala@iramako.pl" splash="szary"
            >centrala@iramako.pl</NavLink
          >
        </div>
        <a
          href="/privacy"
          class="text-[13px] text-muted hover:text-ink sm:text-sm"
          >polityka prywatności</a
        >
      </div>
      <Logo class="w-[68px] sm:w-[84px]" />
    </div>
  </Container>
</footer>
