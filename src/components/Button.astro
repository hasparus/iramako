---
interface Props {
  href: string;
  variant?: "primary" | "outline";
  target?: string;
  rel?: string;
}

const { href, variant = "outline", target, rel } = Astro.props;

const base =
  "inline-flex min-h-12 items-center gap-3 border px-4 text-[clamp(.92rem,1vw,1.05rem)] uppercase tracking-[0.12em] [text-box:trim-both_cap_alphabetic]";

const variants = {
  primary: `${base} border-ink bg-ink text-cream hover:bg-transparent hover:text-ink`,
  outline: `${base} border-primary text-primary hover:bg-primary hover:text-cream`,
} as const;
---

<a class={variants[variant]} href={href} target={target} rel={rel}>
  <slot name="icon" />
  <slot />
</a>
