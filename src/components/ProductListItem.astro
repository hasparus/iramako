---
interface Props {
  number: string;
  name: string;
  copy: string;
  index: number;
  total: number;
  class?: string;
}

const { number, name, copy, index, total, class: className } = Astro.props;
---

<article
  class:list={[
    "border-b border-rule py-8 lg:min-h-55 lg:border-b-0 lg:py-[clamp(34px,4vw,58px)]",
    index !== total - 1 && "lg:border-r",
    index === 0
      ? "lg:pr-[clamp(26px,4vw,78px)]"
      : "lg:px-[clamp(26px,4vw,78px)]",
    index === total - 1 && "border-b-0 lg:pr-0",
    className,
  ]}
>
  <p class="mb-6 text-[0.92rem] font-bold leading-none text-ink">
    {number}
  </p>
  <h2
    class="mb-4 text-[clamp(2rem,3vw,3.1rem)] font-bold leading-[0.95] tracking-[-0.04em] text-ink"
  >
    {name}
  </h2>
  <p
    class="m-0 max-w-65 text-[clamp(1rem,1.1vw,1.18rem)] leading-[1.45] text-muted"
  >
    {copy}
  </p>
</article>
