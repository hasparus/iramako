---
import { Image as AstroImage } from "astro:assets";
import type { ComponentProps } from "astro/types";
import { readFile } from "node:fs/promises";
import { getPlaiceholder } from "plaiceholder";

// the project's image component for raster product/brand photos: astro:assets
// <Image> plus a blur-up placeholder. Same props, but src must be a local
// asset (we need its bytes for the placeholder); everything else forwards.
type Props = Omit<ComponentProps<typeof AstroImage>, "src"> & {
  src: ImageMetadata;
};

const { src, alt, class: className, ...img } = Astro.props;

// plaiceholder needs the source bytes; fsPath is the on-disk path Astro stamps
// onto local imports. ponytail: fsPath is @internal in Astro and could vanish
// on a major upgrade — guarded so the build fails loudly, not with a cryptic
// ENOENT. If it ever breaks, move blur generation to a Vite `?blur` import.
const fsPath = (src as ImageMetadata & { fsPath?: string }).fsPath;
if (!fsPath) {
  throw new Error(
    `<Image> needs a locally imported image (no fsPath on src: ${src.src}).`,
  );
}
const { base64 } = await getPlaiceholder(await readFile(fsPath));
---

{/* the real <Image> carries width/height, so it reserves the box (no shift);
  the blur is absolutely positioned to fill that same box and fades out once the
  photo paints. It's an <img> (not a background) so transparent cutouts stay
  transparent instead of showing a blurred rectangle. */}
<div class="relative">
  <img
    src={base64}
    alt=""
    aria-hidden="true"
    data-blur
    class="pointer-events-none absolute inset-0 h-full w-full object-contain blur-xl transition-opacity duration-500"
  />
  <AstroImage src={src} alt={alt} class:list={["relative", className]} {...img} />
</div>

<script>
  for (const blur of document.querySelectorAll<HTMLImageElement>("[data-blur]")) {
    const real = blur.parentElement!.querySelector<HTMLImageElement>(
      "img:not([data-blur])",
    )!;
    const hide = () => (blur.style.opacity = "0");
    // hide once the photo is painted — or failed, so a broken image never
    // leaves the blur stuck on screen.
    if (real.complete) hide();
    else {
      real.addEventListener("load", hide, { once: true });
      real.addEventListener("error", hide, { once: true });
    }
  }
</script>
