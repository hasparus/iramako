---
import { Image as AstroImage } from "astro:assets";
import type { ComponentProps } from "astro/types";
import { readFile } from "node:fs/promises";
import { getPlaiceholder } from "plaiceholder";

// the project's image component for raster photos. astro:assets <Image> (so the
// width/height reserve the box — no layout shift) that fades the photo in once
// it paints. Pass `blur` to also show a Plaiceholder blur-up behind it; best for
// rectangular photos, not transparent cutouts (the blur would show as an edge).
type Props = ComponentProps<typeof AstroImage> & { blur?: boolean };

const { class: className, blur, src, ...img } = Astro.props;

let base64: string | undefined;
if (blur) {
  // fsPath is the on-disk source (Astro stamps it onto local imports but omits
  // it from the public type). ponytail: it's @internal — guarded so the build
  // fails loudly if a future Astro drops it; upgrade path is a Vite `?blur` import.
  const fsPath = (src as ImageMetadata & { fsPath?: string }).fsPath;
  if (!fsPath) {
    throw new Error(
      `<Image blur> needs a local image (no fsPath on ${src.src}).`,
    );
  }
  ({ base64 } = await getPlaiceholder(await readFile(fsPath)));
}
---

<div class="relative">
  {
    base64 && (
      <img
        src={base64}
        alt=""
        aria-hidden="true"
        class="pointer-events-none absolute inset-0 h-full w-full object-cover blur-xl"
      />
    )
  }
  <AstroImage
    data-fade
    src={src}
    class:list={["fade-img relative", className]}
    {...img}
  />
</div>

<style>
  .fade-img {
    opacity: 0;
    transition: opacity 0.7s ease;
  }
  .fade-img.is-loaded {
    opacity: 1;
  }
  @media (prefers-reduced-motion: reduce) {
    .fade-img {
      transition: none;
    }
  }
</style>

{/* without JS the photo must never stay hidden */}
<noscript>
  <style>
    .fade-img {
      opacity: 1;
    }
  </style>
</noscript>

<script>
  for (const el of document.querySelectorAll<HTMLImageElement>("[data-fade]")) {
    const show = () => el.classList.add("is-loaded");
    // fade once painted — or on error, so a broken image never stays hidden
    if (el.complete) show();
    else {
      el.addEventListener("load", show, { once: true });
      el.addEventListener("error", show, { once: true });
    }
  }
</script>
