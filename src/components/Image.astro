---
import { Image as AstroImage } from "astro:assets";
import type { ComponentProps } from "astro/types";

// the project's image component for raster photos: astro:assets <Image> that
// fades in once it paints, so it doesn't pop in over the reserved box. Same
// props as <Image>; everything forwards untouched.
type Props = ComponentProps<typeof AstroImage>;

const { class: className, ...img } = Astro.props;
---

<AstroImage data-fade class:list={["fade-img", className]} {...img} />

<style>
  .fade-img {
    opacity: 0;
    transition: opacity 0.7s ease;
  }
  .fade-img.is-loaded {
    opacity: 1;
  }
  @media (prefers-reduced-motion: reduce) {
    .fade-img {
      transition: none;
    }
  }
</style>

{/* without JS the image must never stay hidden */}
<noscript>
  <style>
    .fade-img {
      opacity: 1;
    }
  </style>
</noscript>

<script>
  for (const el of document.querySelectorAll<HTMLImageElement>("[data-fade]")) {
    const show = () => el.classList.add("is-loaded");
    // fade once painted — or on error, so a broken image never stays hidden
    if (el.complete) show();
    else {
      el.addEventListener("load", show, { once: true });
      el.addEventListener("error", show, { once: true });
    }
  }
</script>
