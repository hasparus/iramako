---
import Container from "./Container.astro";
import Logo from "./Logo.astro";
import NavLink from "./NavLink.astro";

interface Props {
  instagramUrl: string;
}

const { instagramUrl } = Astro.props;
---

<header class="relative z-40 border-b border-rule">
  <Container
    class="flex flex-wrap items-center justify-between gap-y-5 py-5 sm:flex-nowrap sm:gap-8 sm:py-7"
  >
    <Logo class="w-[42px] sm:w-[clamp(41px,3.33vw,54px)]" />
    <button
      id="nav-toggle"
      class="group flex size-10 items-center justify-center text-ink sm:hidden"
      aria-expanded="false"
      aria-controls="site-nav"
      aria-label="menu"
    >
      <svg
        class="size-6 group-aria-expanded:hidden"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        aria-hidden="true"
      >
        <path d="M3.75 6.75h16.5M3.75 12h16.5M3.75 17.25h16.5"></path>
      </svg>
      <svg
        class="hidden size-6 group-aria-expanded:block"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        aria-hidden="true"
      >
        <path d="M6 18 18 6M6 6l12 12"></path>
      </svg>
    </button>
    <nav
      id="site-nav"
      class="hidden w-full flex-col gap-4 pb-2 text-base leading-tight text-ink data-open:flex sm:flex sm:w-auto sm:flex-row sm:flex-wrap sm:items-center sm:justify-end sm:gap-x-[clamp(18px,4vw,72px)] sm:gap-y-2 sm:pb-0 sm:text-[clamp(.9rem,1.1vw,1.08rem)]"
      aria-label="główna"
    >
      <NavLink href="#skladniki" splash="arbuz">składniki</NavLink>
      <NavLink href="#kosmetyki" splash="kobalt">kosmetyki</NavLink>
      <NavLink
        href={instagramUrl}
        target="_blank"
        rel="noreferrer"
        splash="kolko13">instagram</NavLink
      >
      <NavLink href="#kontakt" splash="szary">kontakt</NavLink>
    </nav>
  </Container>
</header>

<script>
  const toggle = document.getElementById("nav-toggle");
  const nav = document.getElementById("site-nav");

  if (toggle && nav) {
    toggle.addEventListener("click", () => {
      const open = toggle.getAttribute("aria-expanded") === "true";
      toggle.setAttribute("aria-expanded", String(!open));
      nav.toggleAttribute("data-open", !open);
    });

    // tapping a link (e.g. a #section anchor) should put the menu away
    for (const link of nav.querySelectorAll("a")) {
      link.addEventListener("click", () => {
        toggle.setAttribute("aria-expanded", "false");
        nav.removeAttribute("data-open");
      });
    }
  }
</script>
