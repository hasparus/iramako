---
import Container from "./Container.astro";
import Logo from "./Logo.astro";
import NavLink from "./NavLink.astro";

interface Props {
  instagramUrl: string;
}

const { instagramUrl } = Astro.props;
---

<header class="relative z-40 border-b border-rule">
  <Container
    class="flex flex-wrap items-center justify-between gap-y-5 py-5 sm:flex-nowrap sm:gap-8 sm:py-7"
  >
    <Logo class="w-[47px] sm:w-[clamp(46px,3.7vw,60px)]" />
    <button
      popovertarget="site-nav"
      class="flex size-10 items-center justify-center text-ink sm:hidden"
      aria-label="menu"
    >
      <svg
        class="size-6"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        aria-hidden="true"
      >
        <path d="M3.75 6.75h16.5M3.75 12h16.5M3.75 17.25h16.5"></path>
      </svg>
    </button>
    {/* mobile: top-layer drawer (popover gives us the toggle, aria-expanded,
        light dismiss, Escape, ::backdrop and tab-order for free); the slide
        is pure CSS via @starting-style + allow-discrete. sm+: plain row. */}
    <nav
      id="site-nav"
      popover
      class="inset-y-0 left-auto right-0 m-0 h-auto w-64 max-w-[80vw] translate-x-full flex-col gap-5 border-0 border-l border-rule bg-cream px-6 pt-28 text-base leading-tight text-ink transition-[translate,display,overlay] transition-discrete duration-300 ease-[cubic-bezier(0.32,0.72,0,1)] open:duration-500 backdrop:bg-ink/15 backdrop:opacity-0 backdrop:transition-[opacity,display,overlay] backdrop:transition-discrete backdrop:duration-300 backdrop:ease-[cubic-bezier(0.32,0.72,0,1)] open:flex open:translate-x-0 open:backdrop:opacity-100 open:backdrop:duration-500 starting:open:translate-x-full starting:open:backdrop:opacity-0 motion-reduce:transition-none motion-reduce:backdrop:transition-none sm:static sm:flex sm:w-auto sm:max-w-none sm:translate-x-0 sm:flex-row sm:flex-wrap sm:items-center sm:justify-end sm:gap-x-[clamp(12px,1.8vw,30px)] sm:gap-y-2 sm:overflow-visible sm:border-l-0 sm:bg-transparent sm:p-0 sm:text-[clamp(.9rem,1.1vw,1.08rem)]"
      aria-label="główna"
    >
      <button
        popovertarget="site-nav"
        popovertargetaction="hide"
        class="absolute right-4 top-5 flex size-10 items-center justify-center text-ink sm:hidden"
        aria-label="zamknij menu"
      >
        <svg
          class="size-6"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          aria-hidden="true"
        >
          <path d="M6 18 18 6M6 6l12 12"></path>
        </svg>
      </button>
      {/* produkty: parent link + nested categories — dropdown on sm+,
          indented sub-list inside the mobile drawer (contents = wrapper
          dissolves so the links flow into the drawer column) */}
      <div data-prod-menu class="group/prod max-sm:contents sm:relative">
        <NavLink href="/#produkty" splash="kobalt">produkty</NavLink>
        <div
          class="flex flex-col gap-4 max-sm:pl-4 sm:absolute sm:left-0 sm:top-full sm:z-50 sm:hidden sm:min-w-44 sm:gap-3 sm:border sm:border-rule sm:bg-cream sm:p-5 sm:group-hover/prod:flex sm:group-focus-within/prod:flex"
        >
          <NavLink href="/#olejki">olejki</NavLink>
          <NavLink href="/#kremy">kremy</NavLink>
          <NavLink href="/#hydrolaty">hydrolaty</NavLink>
          <NavLink href="/#glinki">glinki</NavLink>
        </div>
      </div>
      <NavLink href="/about" splash="arbuz">o marce</NavLink>
      <NavLink href="/#skladniki" splash="kolko13">składniki</NavLink>
      <NavLink href="/contact" splash="szary">kontakt</NavLink>
    </nav>
  </Container>
</header>

<script>
  const nav = document.getElementById("site-nav");
  const desktop = window.matchMedia("(width >= 40rem)");

  if (nav && "hidePopover" in nav) {
    const close = () => {
      if (nav.matches(":popover-open")) nav.hidePopover();
    };

    // anchors don't light-dismiss the popover; put the menu away on navigation
    for (const link of nav.querySelectorAll("a")) {
      link.addEventListener("click", close);
    }

    // the breakpoint flip swaps the inline row and the (closed) drawer;
    // allow-discrete would animate that swap as a drawer slide-out, so
    // suppress the transition for it. growing past sm also closes a stray
    // open drawer that would otherwise sit in the top layer over the row
    desktop.addEventListener("change", (e) => {
      nav.style.transitionProperty = "none";
      if (e.matches) close();
      requestAnimationFrame(() =>
        requestAnimationFrame(() => {
          nav.style.transitionProperty = "";
        }),
      );
    });
  }

  // produkty submenu: arrow keys move between the parent link and categories
  const prodMenu = document.querySelector("[data-prod-menu]");
  if (prodMenu) {
    const links = [...prodMenu.querySelectorAll("a")];
    prodMenu.addEventListener("keydown", (e) => {
      const i = links.indexOf(document.activeElement as HTMLAnchorElement);
      if (i === -1) return;
      let next = -1;
      if (e.key === "ArrowDown") next = (i + 1) % links.length;
      else if (e.key === "ArrowUp") next = (i - 1 + links.length) % links.length;
      else if (e.key === "Home") next = 0;
      else if (e.key === "End") next = links.length - 1;
      else if (e.key === "Escape" && i > 0 && desktop.matches)
        next = 0; // collapse dropdown back to parent link
      else return;
      e.preventDefault();
      links[next].focus();
    });
  }
</script>
