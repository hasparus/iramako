---
import Container from "./Container.astro";
import Logo from "./Logo.astro";
import NavLink from "./NavLink.astro";

interface Props {
  instagramUrl: string;
}

const { instagramUrl } = Astro.props;
---

<header class="relative z-40 border-b border-rule">
  <Container
    class="flex flex-wrap items-center justify-between gap-y-5 py-5 sm:flex-nowrap sm:gap-8 sm:py-7"
  >
    <Logo class="w-[42px] sm:w-[clamp(41px,3.33vw,54px)]" />
    <button
      popovertarget="site-nav"
      class="flex size-10 items-center justify-center text-ink sm:hidden"
      aria-label="menu"
    >
      <svg
        class="size-6"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        aria-hidden="true"
      >
        <path d="M3.75 6.75h16.5M3.75 12h16.5M3.75 17.25h16.5"></path>
      </svg>
    </button>
    {/* mobile: top-layer drawer (popover gives us the toggle, aria-expanded,
        light dismiss, Escape, ::backdrop and tab-order for free); the slide
        is pure CSS via @starting-style + allow-discrete. We animate `transform`
        rather than the `translate-x-*` utilities: those compile to the CSS
        `translate` property fed by @property custom props (inherits:false),
        and Safari ignores their @starting-style start value, so the drawer
        snapped open instead of sliding. transform has no such indirection and
        animates correctly in Safari, Chrome and Firefox. The ::backdrop fades
        on its own `linear` curve (not the drawer's spatial ease-out, which
        front-loads opacity and makes the scrim pop in); it runs a touch longer
        than the slide so the dim lands softly. sm+: plain row. */}
    <nav
      id="site-nav"
      popover
      class="inset-y-0 left-auto right-0 m-0 h-auto w-64 max-w-[80vw] [transform:translateX(100%)] flex-col gap-5 border-0 border-l border-rule bg-cream px-6 pt-28 text-base leading-tight text-ink transition-[transform,display,overlay] transition-discrete duration-300 ease-[cubic-bezier(0.32,0.72,0,1)] open:duration-500 backdrop:bg-ink/15 backdrop:opacity-0 backdrop:transition-[opacity,display,overlay] backdrop:transition-discrete backdrop:duration-300 backdrop:ease-linear open:flex open:[transform:translateX(0)] open:backdrop:opacity-100 open:backdrop:duration-[600ms] starting:open:[transform:translateX(100%)] starting:open:backdrop:opacity-0 motion-reduce:transition-none motion-reduce:backdrop:transition-none sm:static sm:flex sm:w-auto sm:max-w-none sm:[transform:translateX(0)] sm:flex-row sm:flex-wrap sm:items-center sm:justify-end sm:gap-x-[clamp(18px,4vw,72px)] sm:gap-y-2 sm:overflow-visible sm:border-l-0 sm:bg-transparent sm:p-0 sm:text-[clamp(.9rem,1.1vw,1.08rem)]"
      aria-label="główna"
    >
      <button
        popovertarget="site-nav"
        popovertargetaction="hide"
        class="absolute right-4 top-5 flex size-10 items-center justify-center text-ink sm:hidden"
        aria-label="zamknij menu"
      >
        <svg
          class="size-6"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          aria-hidden="true"
        >
          <path d="M6 18 18 6M6 6l12 12"></path>
        </svg>
      </button>
      <NavLink href="#skladniki" splash="arbuz">składniki</NavLink>
      <NavLink href="#kosmetyki" splash="kobalt">kosmetyki</NavLink>
      <NavLink
        href={instagramUrl}
        target="_blank"
        rel="noreferrer"
        splash="kolko13">instagram</NavLink
      >
      <NavLink href="#kontakt" splash="szary">kontakt</NavLink>
    </nav>
  </Container>
</header>

<script>
  const nav = document.getElementById("site-nav");

  if (nav && "hidePopover" in nav) {
    const close = () => {
      if (nav.matches(":popover-open")) nav.hidePopover();
    };

    // anchors don't light-dismiss the popover; put the menu away on navigation
    for (const link of nav.querySelectorAll("a")) {
      link.addEventListener("click", close);
    }

    // the breakpoint flip swaps the inline row and the (closed) drawer;
    // allow-discrete would animate that swap as a drawer slide-out, so
    // suppress the transition for it. growing past sm also closes a stray
    // open drawer that would otherwise sit in the top layer over the row
    window.matchMedia("(width >= 40rem)").addEventListener("change", (e) => {
      nav.style.transitionProperty = "none";
      if (e.matches) close();
      requestAnimationFrame(() =>
        requestAnimationFrame(() => {
          nav.style.transitionProperty = "";
        }),
      );
    });
  }
</script>
